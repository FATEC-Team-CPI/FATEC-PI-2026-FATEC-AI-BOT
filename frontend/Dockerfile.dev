FROM node:25-alpine

WORKDIR /app

# Cypress binary is not required to run Vite dev server in this container.
ENV CYPRESS_INSTALL_BINARY=0

EXPOSE 5173

CMD ["sh", "-c", "if [ ! -d node_modules ] || [ -z \"$(ls -A node_modules 2>/dev/null)\" ]; then npm ci --no-audit --no-fund --ignore-scripts; fi; npm run dev -- --host 0.0.0.0 --port 5173"]
