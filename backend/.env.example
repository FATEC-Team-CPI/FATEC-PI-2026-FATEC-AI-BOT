# ============================================================================
# FATEC AI Bot — Variáveis de Ambiente
# ============================================================================
# Copiar este arquivo para .env e preencher com seus valores reais

# ============================================================================
# GROQ API
# ============================================================================
# Obter em: https://console.groq.com/keys
GROQ_API_KEY=gsk_seu_api_key_aqui_123456789

# ============================================================================
# LocalStack (AWS Mock)
# ============================================================================
LOCALSTACK_AUTH_TOKEN=ls-seu_token_aqui
SERVICES=dynamodb
AWS_DEFAULT_REGION=us-east-1
DDB_TABLE_NAME=fatec-ai-bot-core
DDB_SEED_EXAMPLES=true
DEBUG=0

# ============================================================================
# DynamoDB Configuration
# ============================================================================
QUARKUS_DYNAMODB_ENDPOINT_OVERRIDE=http://localstack:4566
QUARKUS_DYNAMODB_AWS_REGION=us-east-1
QUARKUS_DYNAMODB_AWS_CREDENTIALS_TYPE=static
QUARKUS_DYNAMODB_AWS_CREDENTIALS_STATIC_PROVIDER_ACCESS_KEY_ID=test
QUARKUS_DYNAMODB_AWS_CREDENTIALS_STATIC_PROVIDER_SECRET_ACCESS_KEY=test
QUARKUS_DEVSERVICES_ENABLED=false

# ============================================================================
# MCP Server Configuration
# ============================================================================
MCP_SERVER_URL=http://mcp-server:8001
MCP_HOST=0.0.0.0
MCP_PORT=8001
MCP_ENV=production

# ============================================================================
# Quarkus Configuration
# ============================================================================
QUARKUS_HTTP_PORT=8082
QUARKUS_HTTP_HOST=0.0.0.0
QUARKUS_LOG_LEVEL=INFO

# ============================================================================
# Vector DB (Opcional - para fases futuras)
# ============================================================================
# Escolha uma das opções abaixo e descomente

# ChromaDB
# VECTOR_DB_TYPE=chroma
# CHROMA_PERSIST_DIR=./data/chroma

# Qdrant
# VECTOR_DB_TYPE=qdrant
# QDRANT_URL=http://qdrant:6333
# QDRANT_COLLECTION=fatec-documents

# PostgreSQL + pgvector
# VECTOR_DB_TYPE=pgvector
# DATABASE_URL=postgresql://fatec:fatec@postgres:5432/fatec_db
